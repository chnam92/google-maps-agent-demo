# ── LLM 인증: 아래 두 방식 중 하나 선택 ──────────────────────────

# [방식 1] Gemini API 키 — Google AI Studio에서 발급 (https://aistudio.google.com/)
GEMINI_API_KEY=your-gemini-api-key

# [방식 2] Cloud 인증 (Vertex AI + ADC) — API 키 불필요.
# 사전 준비: gcloud auth application-default login + Vertex AI API 활성화
# GOOGLE_GENAI_USE_ENTERPRISE=TRUE
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=global
# VERTEX_MODEL=gemini-3-flash-preview

# Google Cloud Console에서 발급 (https://console.cloud.google.com/google/maps-apis/credentials)
# 필요 API: Maps JavaScript API, Places API (New)/Places UI Kit, Routes API, Geocoding API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# (선택) 에이전트 서버 주소 — 기본값 http://localhost:10002
# SERVER_URL=http://localhost:10002

# (선택) LiteLLM 모델 오버라이드 — 기본값 gemini/gemini-3-flash-preview
# LITELLM_MODEL=gemini/gemini-2.5-flash
